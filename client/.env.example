# API base (used by getBackendBaseUrl if set)
REACT_APP_API_URL=http://localhost:8000

# --- Supabase (optional: email/password still works without these) ---
# Project Settings → API
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# anon / public key (JWT or publishable key per your Supabase project)
REACT_APP_SUPABASE_ANON_KEY=

# Legacy Stack (remove if unused)
REACT_APP_STACK_PROJECT_ID=your_stack_project_id
REACT_APP_STACK_PUBLISHABLE_KEY=your_stack_publishable_key
