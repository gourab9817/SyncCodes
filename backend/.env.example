# --- Database (Supabase Postgres recommended) ---
# Pooled connection for Prisma runtime (port 6543 + pgbouncer)
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for migrations (port 5432)
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- App JWT (email/password login + refresh cookie signing) ---
JWT_SECRET="generate-a-long-random-string"
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Supabase Auth (verify OAuth / magic-link access tokens on API + Socket.IO) ---
# Project Settings → API → Project URL
SUPABASE_URL="https://[REF].supabase.co"
# Optional: JWT Secret for legacy HS256 projects only.
# Modern Supabase projects use asymmetric keys (ES256/RS256) and are verified via JWKS automatically.
SUPABASE_JWT_SECRET=""

# Optional: legacy Neon OAuth (RS256 JWKS) — omit if unused
# NEON_JWKS="https://.../jwks.json"
STACK_SECRET_SERVER_KEY=""

# Google Gemini AI
GEMINI_API_KEY=""

# App
PORT=8000
CLIENT_URL="http://localhost:3000"
# Optional: extra CORS/Socket.IO origins (comma-separated), e.g. https://preview.vercel.app,https://app.com
ALLOWED_ORIGINS=
# Force serving ../client/build from this process (default: auto if that folder exists; false for API-only Docker)
SERVE_CLIENT_STATIC=
NODE_ENV="development"

SOCKET_AUTH_REQUIRED=false
REDIS_URL=

YJS_MAX_UPDATE_BYTES=262144
YJS_MAX_STATE_BYTES=524288
YJS_UPDATES_PER_WINDOW=200
YJS_WINDOW_MS=10000
ROOM_JOIN_PER_WINDOW=30
ROOM_JOIN_WINDOW_MS=60000
CODE_SNAPSHOT_MAX_CHARS=500000
WHITEBOARD_MAX_STROKES_BYTES=1048576

EXECUTION_BACKEND=local
PISTON_API_URL=
EXECUTION_REQUIRE_AUTH=true
EXECUTION_MAX_SOURCE_CHARS=100000
