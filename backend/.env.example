# Neon PostgreSQL — pooled (runtime queries via Prisma Client)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.neon.tech/neondb?sslmode=require"
# Neon PostgreSQL — direct (Prisma migrations only)
DIRECT_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"

# Neon Auth / Stack Auth
NEON_JWKS="https://<your-neon-host>/auth/.well-known/jwks.json"
STACK_SECRET_SERVER_KEY=""

# Google Gemini AI
GEMINI_API_KEY=""

# App
PORT=8000
CLIENT_URL="http://localhost:3000"
NODE_ENV="development"

# Socket.IO — production defaults SOCKET_AUTH_REQUIRED to true unless overridden
SOCKET_AUTH_REQUIRED=false
# Optional: Redis for multi-process / multi-node Socket.IO (same URL for pub+sub)
REDIS_URL=

# Yjs / socket abuse limits (optional)
YJS_MAX_UPDATE_BYTES=262144
YJS_MAX_STATE_BYTES=524288
YJS_UPDATES_PER_WINDOW=200
YJS_WINDOW_MS=10000
ROOM_JOIN_PER_WINDOW=30
ROOM_JOIN_WINDOW_MS=60000
CODE_SNAPSHOT_MAX_CHARS=500000
WHITEBOARD_MAX_STROKES_BYTES=1048576

# --- Code execution ---
# EXECUTION_BACKEND options:
#   local    = run compilers on the API host  ← DEV ONLY, BLOCKED in production
#   piston   = self-hosted Piston (required for production)
#   disabled = disables code execution entirely (safe fallback)
#
# For production: spin up Piston with docker-compose.execution.yml and set:
#   EXECUTION_BACKEND=piston
#   PISTON_API_URL=http://piston:2000   (internal VPC/Docker network only — never expose publicly)
EXECUTION_BACKEND=local

# Internal Piston URL (Docker network / VPC only)
PISTON_API_URL=

# Require JWT to run code. Defaults to true — set false only for local dev testing.
# WARNING: setting false in production allows unauthenticated code execution.
EXECUTION_REQUIRE_AUTH=true

EXECUTION_MAX_SOURCE_CHARS=100000
